{
  "name": "dimich-digital-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"if (Test-Path .next) { Remove-Item -Recurse -Force .next }; npm.cmd run dev\"",
    "build": "next build",
    "build:clean": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"if (Test-Path .next) { Remove-Item -Recurse -Force .next }; npm.cmd run build\"",
    "start": "next start",
    "lint": "next lint",
    "verify:local": "node scripts/verify-local.mjs"
  },
  "dependencies": {
    "next": "15.5.21",
    "react": "19.2.8",
    "react-dom": "19.2.8"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "15.5.21",
    "postcss": "8.5.22",
    "tailwindcss": "3.4.7",
    "typescript": "5.5.4"
  },
  "overrides": {
    "brace-expansion": "1.1.16",
    "postcss": "8.5.22",
    "sharp": "0.35.0"
  }
}
